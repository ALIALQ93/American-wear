# =============================================================================
# كيف تستخدم هذا الملف؟
# -----------------------------------------------------------------------------
# 1) انسخ الملف بالكامل والصقه في نفس المجلد باسم:  .env   (بدون كلمة example)
# 2) املأ القيم أسفل كل سطر = حسب «أين في Supabase» المذكور في التعليق
# 3) احفظ الملف ثم شغّل من الطرفية في مجلد المشروع:  npm run dev
# ملاحظة: لا ترفع ملف .env إلى Git ولا ترسل محتواه في الدردشات (أسرار).
# =============================================================================

# -----------------------------------------------------------------------------
# PORT — ليس من Supabase
# -----------------------------------------------------------------------------
# رقم منفذ خادم Node (Express). Vite يوجّه طلبات /api إلى 127.0.0.1:هذا_الرقم
# إن غيّرته هنا فتأكد أن لا برنامج آخر يستخدم نفس المنفذ.
PORT=3000

# -----------------------------------------------------------------------------
# DATABASE_URL — قاعدة البيانات (Postgres)
# أين في Supabase؟
#   الشريط الأيسر: أيقونة الترس ⚙ → Project settings
#   ثم من القائمة الجانلية: Database
#   ثم قسم Connection string:
#     - إن عمل عندك الرابط المباشر: نسخ «URI» الذي يضم db.xxx.supabase.co
#     - إن ظهر خطأ اتصال أو ETIMEDOUT أو IPv6: انسخ «Session pooler» (وضع Session)
#   استبدل placeholder كلمة المرور في النص بكلمة مرور قاعدة البيانات الحقيقية.
#   إن احتوت كلمة المرور على = أو @ أو # رمّزها في الرابط (مثلاً = تصبح %3D).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# عند مشاكل DNS على Windows أو no_ipv4_for_host — أزل # من السطر التالي:
# DATABASE_FORCE_PUBLIC_DNS=1
# DATABASE_DNS_RETRIES=5
# DATABASE_CONNECT_TIMEOUT_MS=40000

# -----------------------------------------------------------------------------
# VITE_SUPABASE_URL و VITE_SUPABASE_PUBLISHABLE_KEY — واجهة تسجيل دخول الإدارة
# أين في Supabase؟
#   الشريط الأيسر: أيقونة الترس ⚙ → Project settings → API
#   - Project URL  ← انسخه في VITE_SUPABASE_URL (يبدأ عادة بـ https://)
#   - Publishable key أو anon public  ← انسخ أحدهما في السطر المناسب أدناه
#   يكفي مفتاح واحد للواجهة: إما publishable (sb_publishable_...) أو anon (JWT يبدأ eyJ)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# بديل أسماء المتغيرات (نفس القيم، مثل معالج Next في Supabase):
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# -----------------------------------------------------------------------------
# SUPABASE_URL و SUPABASE_ANON_KEY — خادم Node (التحقق من جلسة الإدارة)
# أين في Supabase؟
#   نفس الصفحة: Project settings → API
#   - Project URL     ← نفس قيمة VITE_SUPABASE_URL عادةً
#   - anon public key ← انسخ المفتاح الذي يبدأ بـ eyJ... (يُفضّل للخادم مع auth.getUser)
# لا تضع مفتاح Secret (sb_secret_) في متغير يبدأ بـ VITE_ أو NEXT_PUBLIC_
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# اختياري — خادم فقط، من صفحة API إن وُجد:
# SUPABASE_SECRET_KEY=sb_secret_...

# -----------------------------------------------------------------------------
# ADMIN_ALLOWED_EMAILS — ليس من زر في Supabase؛ تكتبه أنت
# -----------------------------------------------------------------------------
# بريد (أو أكثر مفصولة بفاصلة إنجليزية) لمستخدم موجود في Supabase → Authentication → Users
# بعد نجاح تسجيل الدخول في لوحة الإدارة يُسمح له إن لم يكن له صف بعد في admin_profiles.
ADMIN_ALLOWED_EMAILS=you@example.com
